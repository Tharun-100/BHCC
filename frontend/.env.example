# Frontend
# Leave this unset to use the recommended same-origin /api proxy.
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Address Next.js uses server-side to reach Django.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Razorpay (public key for checkout, optional)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
