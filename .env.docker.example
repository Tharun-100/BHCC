# Copy this file to .env.docker before starting Docker Compose.
# Use long, random values for production.
POSTGRES_DB=bhcc
POSTGRES_USER=bhcc_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret

# Public URLs/hosts for the server. Comma-separate multiple values.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Optional integrations
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
SENDGRID_API_KEY=
CLINIC_TO_EMAIL=bhaktivedantahealthcarecentre@gmail.com
